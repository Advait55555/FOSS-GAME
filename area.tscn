[gd_scene format=3 uid="uid://kp3tjbfrep57"]

[sub_resource type="GDScript" id="GDScript_4kikl"]
resource_name = "doors.gd"
script/source = "extends Area2D

@export_file(\"world.tscn\") var destination_scene: String # Allows selecting the next scene in the Inspector
@export var destination_door_tag: String # A unique tag to identify the spawn point in the next scene

var player_in_area: bool = false

func _on_body_entered(body):
    # Check if the entering body is the player (ensure player is in a 'player' group)
    if body.is_in_group(\"player\"):
        player_in_area = true
        # Optional: display a prompt (e.g., \"Press Enter to use door\")

func _on_body_exited(body):
    if body.is_in_group(\"player\"):
        player_in_area = false

func _process(delta):
    if player_in_area and Input.is_action_just_pressed(\"ui_accept\"): # 'ui_accept' is the default Enter key
        # Call a global function to handle the scene change
        SceneManager.change_level(destination_scene, destination_door_tag)
"

